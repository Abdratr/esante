<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Dashboard eSante Mali</title>

    <link rel="icon" href="{{ asset('images/esante.png') }}">

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>

        /* ================= BASE ================= */
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Segoe UI', sans-serif;
        }

        body{
            display:flex;
            min-height:100vh;

            /* IMAGE DE FOND FIXE */
            background: url('{{ asset("images/fond.png") }}') no-repeat center center fixed;
            background-size: cover;
        }

        /* OVERLAY GLOBAL */
        body::before{
            content:"";
            position:fixed;
            top:0;
            left:0;
            width:100%;
            height:100%;
            background:rgba(0,0,0,0.55);
            z-index:-1;
        }

        /* ================= SIDEBAR ================= */
        .sidebar{
            width:260px;
            height:100vh;
            position:fixed;

            background: rgba(17, 24, 39, 0.65);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);

            border-right:1px solid rgba(255,255,255,0.08);
            padding:20px;
        }

        .logo{
            display:flex;
            align-items:center;
            gap:10px;
            margin-bottom:30px;
        }

        .logo img{
            width:40px;
        }

        .logo h2{
            font-size:18px;
            color:#00e6b8;
        }

        .menu a{
            display:flex;
            align-items:center;
            gap:10px;
            padding:12px;
            color:#cbd5e1;
            text-decoration:none;
            border-radius:10px;
            margin-bottom:8px;
            transition:0.3s;
        }

        .menu a:hover{
            background:rgba(0,230,184,0.15);
            color:#00e6b8;
        }

        /* ================= MAIN ================= */
        .main{
            margin-left:260px;
            width:100%;
        }

        /* TOPBAR */
        .topbar{
            display:flex;
            justify-content:space-between;
            align-items:center;
            padding:15px 25px;

            background: rgba(17, 24, 39, 0.55);
            backdrop-filter: blur(10px);

            border-bottom:1px solid rgba(255,255,255,0.08);
        }

        .topbar h2{
            color:white;
        }

        .admin-box{
            display:flex;
            align-items:center;
            gap:10px;

            background: rgba(255,255,255,0.06);
            padding:8px 12px;
            border-radius:12px;
            backdrop-filter: blur(8px);
        }

        .admin-box img{
            width:40px;
            height:40px;
            border-radius:50%;
        }

        /* ================= CONTENT ================= */
        .content{
            padding:25px;
        }

        /* LOGOS */
        .header-logos{
            display:flex;
            justify-content:space-between;
            margin-bottom:20px;
        }

        .header-logos img{
            width:65px;
            background:white;
            padding:5px;
            border-radius:10px;
        }

        /* ================= STATS ================= */
        .stats{
            display:grid;
            grid-template-columns:repeat(4,1fr);
            gap:15px;
        }

        .card{
            background: rgba(31, 41, 55, 0.55);
            backdrop-filter: blur(12px);

            border:1px solid rgba(255,255,255,0.08);
            padding:20px;
            border-radius:14px;
            transition:0.3s;
        }

        .card:hover{
            transform:translateY(-5px);
            background: rgba(0,230,184,0.15);
        }

        .card i{
            font-size:22px;
            color:#00e6b8;
        }

        .card h3{
            margin-top:10px;
        }

        .card p{
            color:#94a3b8;
            font-size:14px;
        }

        /* ================= MODULES ================= */
        .modules{
            margin-top:30px;
            display:grid;
            grid-template-columns:repeat(3,1fr);
            gap:15px;
        }

        .module{
            background: rgba(31, 41, 55, 0.55);
            backdrop-filter: blur(10px);

            border:1px solid rgba(255,255,255,0.08);

            padding:20px;
            border-radius:14px;
            transition:0.3s;
            cursor:pointer;
            text-align:center;
        }

        .module:hover{
            background: rgba(0,230,184,0.18);
            transform:scale(1.03);
        }

        .module i{
            font-size:25px;
            color:#00e6b8;
        }

        /* ================= LIVE ACTIVITIES ================= */
        .live-container{
            margin-top:30px;
            background: rgba(31, 41, 55, 0.55);
            backdrop-filter: blur(12px);

            border:1px solid rgba(255,255,255,0.08);

            padding:20px;
            border-radius:14px;
        }

        .live-header{
            display:flex;
            justify-content:space-between;
            align-items:center;
            margin-bottom:15px;
        }

        .live-header h2{
            font-size:16px;
            color:#00e6b8;
        }

        .pulse{
            width:10px;
            height:10px;
            background:#00e6b8;
            border-radius:50%;
            animation:pulse 1.5s infinite;
        }

        @keyframes pulse{
            0%{transform:scale(1);opacity:1;}
            50%{transform:scale(1.5);opacity:0.5;}
            100%{transform:scale(1);opacity:1;}
        }

        .activity{
            display:flex;
            gap:10px;
            padding:10px;
            border-bottom:1px solid rgba(255,255,255,0.08);
        }

        .activity i{
            color:#00e6b8;
            margin-top:3px;
        }

        .activity small{
            color:#9ca3af;
        }

    </style>
</head>

<body>

<!-- ================= SIDEBAR ================= -->
<div class="sidebar">

    <div class="logo">
        <img src="{{ asset('images/esante.png') }}">
        <h2>eSante Mali</h2>
    </div>

    <div class="menu">
        <a href="#"><i class="fa fa-chart-line"></i> Dashboard</a>
        <a href="#"><i class="fa fa-hospital"></i> Hôpitaux</a>
        <a href="#"><i class="fa fa-user-md"></i> Médecins</a>
        <a href="#"><i class="fa fa-user-injured"></i> Patients</a>
        <a href="#"><i class="fa fa-calendar"></i> Rendez-vous</a>
        <a href="#"><i class="fa fa-chart-pie"></i> Statistiques</a>
        <a href="{{ path('admin_logout') }}"><i class="fa fa-sign-out-alt"></i> Déconnexion</a>
    </div>

</div>

<!-- ================= MAIN ================= -->
<div class="main">

    <!-- TOPBAR -->
    <div class="topbar">

        <h2>Tableau de bord</h2>

        <div class="admin-box">

            {% if app.user.photo %}
                <img src="{{ asset(app.user.photo) }}">
            {% else %}
                <img src="{{ asset('images/default-user.png') }}">
            {% endif %}

            <div>
                <strong>{{ app.user.nomComplet }}</strong><br>
                <small>{{ app.user.email }}</small>
            </div>

        </div>

    </div>

    <!-- CONTENT -->
    <div class="content">

        <!-- LOGOS -->
        <div class="header-logos">
            <img src="{{ asset('images/esante.png') }}">
            <img src="{{ asset('images/mali.jpeg') }}">
        </div>

        <!-- STATS -->
        <div class="stats">

            <div class="card">
                <i class="fa fa-hospital"></i>
                <h3>Hôpitaux</h3>
                <p>Gestion nationale</p>
            </div>

            <div class="card">
                <i class="fa fa-user-md"></i>
                <h3>Médecins</h3>
                <p>Personnel médical</p>
            </div>

            <div class="card">
                <i class="fa fa-user-injured"></i>
                <h3>Patients</h3>
                <p>Dossiers médicaux</p>
            </div>

            <div class="card">
                <i class="fa fa-calendar"></i>
                <h3>Rendez-vous</h3>
                <p>Planification</p>
            </div>

        </div>

        <!-- MODULES -->
        <div class="modules">

            <div class="module">
                <i class="fa fa-building"></i>
                <p>Cliniques privées</p>
            </div>

            <div class="module">
                <i class="fa fa-shield"></i>
                <p>Sécurité</p>
            </div>

            <div class="module">
                <i class="fa fa-chart-line"></i>
                <p>Analytique nationale</p>
            </div>

        </div>

        <!-- LIVE ACTIVITIES -->
        <div class="live-container">

            <div class="live-header">
                <h2>Activités en temps réel</h2>
                <span class="pulse"></span>
            </div>

            <div class="activity">
                <i class="fa fa-user-plus"></i>
                <div>
                    <p>Nouvel administrateur inscrit</p>
                    <small>à l’instant</small>
                </div>
            </div>

            <div class="activity">
                <i class="fa fa-hospital"></i>
                <div>
                    <p>Hôpital ajouté à Bamako</p>
                    <small>il y a 2 min</small>
                </div>
            </div>

            <div class="activity">
                <i class="fa fa-calendar-check"></i>
                <div>
                    <p>Rendez-vous confirmé</p>
                    <small>il y a 5 min</small>
                </div>
            </div>

        </div>

    </div>

</div>

</body>
</html>